# ─── LLM Provider API Keys ───────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# DeepSeek (coming soon)
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI (coming soon)
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (coming soon)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── System Settings ──────────────────────────────────────────────────────────
# SQL database URL for agent memory (default: local SQLite)
DATABASE_URL=sqlite:///./agent_memory.db

# Workspace root — agents are sandboxed to this path
WORKSPACE_ROOT=/home/kabir/Documents/Hackathons/agent_system/workspace

# ─── Safety Limits ────────────────────────────────────────────────────────────
MAX_ITERATIONS=12
RECURSION_LIMIT=50
GLOBAL_TIMEOUT_SECONDS=120
TOOL_TIMEOUT_SECONDS=20
MAX_CONSECUTIVE_TOOL_FAILURES=3
MAX_FORMAT_RETRIES=2

# ─── Model Settings ───────────────────────────────────────────────────────────
DEFAULT_TEMPERATURE=0.2
WINDOW_BUFFER_SIZE=8
