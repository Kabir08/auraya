# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── Auth ──────────────────────────────────────────────────────────────────────
AURAYA_API_KEY=change_me_in_production

# ── Replicate (SAM segmentation) ─────────────────────────────────────────────
REPLICATE_API_TOKEN=your_replicate_token_here

# ── Tripo AI (3D mesh generation) ────────────────────────────────────────────
TRIPO_API_KEY=your_tripo_api_key_here

# ── Cloudinary (temp image hosting so APIs can fetch images) ─────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Asset settings ────────────────────────────────────────────────────────────
ASSET_DIR=./assets
ASSET_BASE_URL=http://localhost:8000/assets
ASSET_TTL_HOURS=24

# ── Rate limits ───────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=10
RATE_LIMIT_SEGMENT=10/minute
RATE_LIMIT_MESH=5/minute
